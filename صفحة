                </a>
                <a href="tel:0538386640" class="btn-rep">
                    <span dir="ltr">053 838 6640</span>
                    <span class="rep-icon">📱</span>
                </a>
            </div>
        </div>
    </div>

    <div class="footer">
        &copy; <span id="year"></span> شركة رواسي الامتياز للإستقدام.
    </div>

